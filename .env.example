New-Item .env.example
Set-Content .env.example "AZURE_SUBSCRIPTION_ID=your-subscription-id`nAZURE_RESOURCE_GROUP=your-resource-group-name`nTEAMS_WEBHOOK_URL=your-teams-incoming-webhook-url`nAZURE_CLIENT_ID=your-service-principal-app-id`nAZURE_CLIENT_SECRET=your-service-principal-secret`nAZURE_TENANT_ID=your-azure-tenant-id"